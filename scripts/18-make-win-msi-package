#!/bin/bash
#set -x
set -euo pipefail
# Change to this script directory
cd "$(dirname "$0")"
cd ..

### Prepare build directory
PROJECT_DIR="$(pwd)"
BUILD_DIR="$PROJECT_DIR/target/wix"

PACKAGE_NAME="tpnote"
BIN_NAME="tpnote"
EXE_NAME="${BIN_NAME}.exe"
BIN_VERSION="$(grep -e '^version' Cargo.toml | sed 's/.*"\(.*\)".*/\1/' | head -n 1)"

echo "Building Windows MSI package for Tp-Note version $BIN_VERSION"

rm -fR "$BUILD_DIR"
mkdir -p "$BUILD_DIR"
chmod 777 "$BUILD_DIR"

cp "./tpnote/tpnote.ico" "$BUILD_DIR"
cp "./build/bin/x86_64-pc-windows-gnu/$EXE_NAME" "$BUILD_DIR"
cp "./wix/tpnote.wxs" "$BUILD_DIR"

### Build Windows installer package
cd "$BUILD_DIR"
chmod 666 *

# Create a version-specific Wix file with proper versioning
# This ensures the UpgradeCode stays constant while version updates
sed "s/Version=\"1.0.0\"/Version=\"$BIN_VERSION\"/" "./wix/tpnote.wxs" > "tpnote-tmp.wxs"

# Enter the dev shell from the flake before running WiX
nix develop "$PROJECT_DIR/wix" --command \
  wine64 wix.exe build tpnote-tmp.wxs -b . -o "$PACKAGE_NAME-$BIN_VERSION-x86_64.msi"

# Copy artifact to new build structure
mkdir -p "$PROJECT_DIR/build/package/x86_64-pc-windows-gnu"
cp "$PACKAGE_NAME-$BIN_VERSION-x86_64.msi" "$PROJECT_DIR/build/package/x86_64-pc-windows-gnu/"

# Clean up the temporary build directory
rm -rf "$BUILD_DIR"

echo "Windows MSI package created and copied to build/package/x86_64-pc-windows-gnu/"
echo "Package name: $PACKAGE_NAME-$BIN_VERSION-x86_64.msi"
