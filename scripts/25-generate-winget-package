#!/bin/bash
# Comprehensive winget packaging script for Tp-Note
# This script automates the entire winget packaging workflow
# and places final artifacts in the proper build directory

set -euo pipefail

# Change to project directory
cd "$(dirname "$0")/.."

echo "=== Tp-Note Winget Packaging Script ==="
echo ""

# Get version from Cargo.toml
VERSION=$(grep -e '^version' Cargo.toml | sed 's/.*"\(.*\)".*/\1/' | head -n 1)
if [ -z "$VERSION" ]; then
    echo "Error: Could not determine version from Cargo.toml"
    exit 1
fi

echo "Using version: $VERSION"

# Check if we have the required tools
echo "Checking prerequisites..."
if ! command -v git &> /dev/null; then
    echo "Error: git is required but not installed"
    exit 1
fi

if ! command -v sha256sum &> /dev/null && ! command -v shasum &> /dev/null; then
    echo "Warning: Neither sha256sum nor shasum available for hash calculation"
fi

# Create temporary directory for manifests
TEMP_DIR="target/winget-temp"
mkdir -p "$TEMP_DIR"

# Create the final build directory structure for winget manifests
# Following winget-pkgs repository structure: manifests/g/getreu/tpnote/<version>/
FINAL_DIR="build/package/winget-manifests/getreu/tpnote/$VERSION"
mkdir -p "$FINAL_DIR"

# Check if we have the MSI file
MSI_FILE="tpnote-${VERSION}-x86_64.msi"
MSI_PATH="build/package/x86_64-pc-windows-gnu/$MSI_FILE"

if [ ! -f "$MSI_PATH" ]; then
    echo "Warning: MSI file not found at $MSI_PATH"
    echo "You need to build the Windows package first"
    echo "Try running: ./scripts/18-make-win-msi-package"
    echo "Or build all targets: ./scripts/14-make-targets"
    read -p "Would you like to try building the Windows package now? (y/N): " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Building Windows MSI package..."
        ./scripts/18-make-win-msi-package
    else
        echo "Please build the MSI package first and try again."
        exit 1
    fi
fi

# Verify the MSI file exists after potential build
if [ ! -f "$MSI_PATH" ]; then
    echo "Error: MSI file still not found after build attempt"
    exit 1
fi

echo "MSI file found: $MSI_FILE"

# Generate winget manifests in temporary directory
echo "Generating winget manifests..."

# Create the main manifest file
cat > "$TEMP_DIR/manifest.yaml" << EOF
PackageIdentifier: getreu.tpnote
PackageVersion: $VERSION
PackageLocale: en-US
Publisher: Jens Getreu
PackageName: Tp-Note
License: MIT/Apache-2.0
ShortDescription: Minimalistic note-taking tool that synchronizes note metadata with filenames
Moniker: tpnote
Tags:
  - note-taking
  - markdown
  - cli
  - productivity
  - text-processing
  - clipboard
  - utility
  - tool
EOF

# Create the version manifest file
cat > "$TEMP_DIR/Version.yaml" << EOF
PackageIdentifier: getreu.tpnote
PackageVersion: $VERSION
ManifestType: version
ManifestVersion: 1.0.0
EOF

# Create the installer manifest
# Calculate SHA256 hash for the MSI file
if command -v sha256sum >/dev/null 2>&1; then
    MSI_HASH=$(sha256sum "$MSI_PATH" | cut -d' ' -f1)
elif command -v shasum >/dev/null 2>&1; then
    MSI_HASH=$(shasum -a 256 "$MSI_PATH" | cut -d' ' -f1)
else
    echo "Warning: Could not calculate SHA256 hash. Please manually add it to the manifest."
    MSI_HASH="<sha256-hash-of-the-msi-file>"
fi

# Create the installer manifest
cat > "$TEMP_DIR/Installer.yaml" << EOF
InstallerType: msi
InstallerUrl: https://blog.getreu.net/projects/tp-note/_downloads/package/x86_64-pc-windows-gnu/$MSI_FILE
InstallerSha256: $MSI_HASH
InstallerSwitches:
  Silent: /quiet
  SilentWithProgress: /passive
EOF

echo "Winget manifests generated successfully for version $VERSION"

# Copy final manifests to build directory with proper structure
echo "Copying manifests to build directory..."
cp "$TEMP_DIR/"* "$FINAL_DIR/"

# Clean up temporary directory
rm -rf "$TEMP_DIR"

echo ""
echo "=== Packaging Summary ==="
echo "Version: $VERSION"
echo "MSI File: $MSI_FILE"
echo "Manifest Location: $FINAL_DIR"
echo ""
echo "Final winget manifests are now available in:"
echo "  $FINAL_DIR/"
echo ""
echo "This follows the proper winget-pkgs repository structure:"
echo "  manifests/g/getreu/tpnote/$VERSION/"
echo ""
echo "Ready for submission to winget-pkgs repository!"
echo ""
echo "Next steps:"
echo "1. Review the generated manifests in $FINAL_DIR"
echo "2. Commit and push to your fork of microsoft/winget-pkgs repository"
echo "3. Create a pull request to the official repository"
echo ""
echo "For local testing:"
echo "winget install --source \"$FINAL_DIR\" --verbose"
echo ""
echo "To validate manifests locally:"
echo "winget validate \"$FINAL_DIR\""
